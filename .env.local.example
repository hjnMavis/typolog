# Typolog — 환경 변수 템플릿
# 이 파일을 .env.local로 복사한 뒤 실제 값을 채워 넣으세요. (.env.local은 절대 커밋 금지)
#
# 변수 분류
#   - NEXT_PUBLIC_* : 클라이언트 번들에 노출됨 (브라우저에서 보여도 되는 공개 값만)
#   - 접두사 없음   : 서버 전용 (admin.ts·db/index.ts 등 server-only 경계 안에서만 사용)
#
# ⚠ 워크트리 주의: Day마다 새 worktree에서 작업할 때 .env.local은 git에 없으므로
#   직접 복사해야 한다. 누락/stale 시 보호 라우트가 500을 던진다 (Phase 2 Day 4.5 QA에서 실제 발생).
#   최신 .env.local을 가진 worktree에서 복사할 것:  cp <그-worktree>/.env.local .env.local

# ===== Supabase (Auth / Storage) =====
# 신규 API 키 체계(sb_publishable_… / sb_secret_…) 사용.
# Supabase Dashboard > Project Settings > API Keys 에서 확인.

# 공개 — 사용처: src/lib/supabase/{browser,server,proxy}.ts, src/lib/supabase/admin.ts
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 공개 — 사용처: src/lib/supabase/{browser,server,proxy}.ts (RLS 적용 클라이언트 키)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# 서버 전용 — NEXT_PUBLIC_ 접두사 절대 금지, 클라이언트 노출 금지 (RLS 우회 키).
# 사용처: src/lib/supabase/admin.ts (server-only 가드)
SUPABASE_SECRET_KEY=your-secret-key

# ===== Drizzle ORM (Postgres 직접 연결 — 마이그레이션·서버 쿼리) =====
# Session pooler URI (port 5432): Dashboard > Connect > Session pooler.
# 서버 전용 — NEXT_PUBLIC_ 접두사 절대 금지, 클라이언트 노출 금지.
# 사용처: src/db/index.ts, scripts/seed-challenges.ts, scripts/verify-rls.ts
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@your-pooler-host:5432/postgres

# ===== App =====
# 현재 코드에서 미참조 — Phase 3 공유 링크·OG 이미지(절대 URL 필요)에서 사용 예정.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== PostHog (배포 후 추가 — 아직 미사용) =====
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===== Sentry (배포 후 추가 — 아직 미사용) =====
# SENTRY_DSN=your-sentry-dsn
